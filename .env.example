# National Assembly e-Library Environment Configuration
# Copy this file to .env and fill in your values

# ============================
# Django Settings
# ============================

DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.nationalassembly.gm

# ============================
# Database Configuration
# ============================

DB_NAME=elibrary_db
DB_USER=elibrary_admin
DB_PASSWORD=change-this-password-in-production
DB_HOST=localhost
DB_PORT=5432

# ============================
# Email Configuration
# ============================

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ============================
# Security Settings
# ============================

# For production, set these to True
SESSION_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False

# ============================
# Logging
# ============================

LOG_LEVEL=INFO
